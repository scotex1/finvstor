# FinVest Pro — .gitignore

# ── NEVER commit these ────────────────────────────────────
.env
firebase/serviceAccountKey.json
*.json.bak

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/
.eggs/

# ── Database ───────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── IDE ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ── Logs ──────────────────────────────────────────────────
*.log
logs/

# ── Testing ───────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
