# ════════════════════════════════════════════════════════════
# FinVest Pro Backend — Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to git
# ════════════════════════════════════════════════════════════

# ── App ─────────────────────────────────────────────────────
DEBUG=False
SECRET_KEY=your-secret-key-run-openssl-rand-hex-32

# ── URLs (used in Cashfree return/notify URLs) ───────────────
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://api.yourdomain.com

# ── CORS — your actual frontend domain ──────────────────────
# Example: ["https://finvestpro.in","https://www.finvestpro.in"]
ALLOWED_ORIGINS=["https://yourdomain.com","http://localhost:3000"]

# ── Firebase ────────────────────────────────────────────────
# Download from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=firebase/serviceAccountKey.json

# ── Cashfree Payment Gateway ─────────────────────────────────
# From Cashfree Dashboard → API Keys
CASHFREE_APP_ID=your-cashfree-app-id
CASHFREE_SECRET_KEY=your-cashfree-secret-key
# From Cashfree Dashboard → Webhooks → Secret
CASHFREE_WEBHOOK_SECRET=your-cashfree-webhook-secret
# Sandbox (testing): https://sandbox.cashfree.com/pg
# Production:        https://api.cashfree.com/pg
CASHFREE_BASE_URL=https://sandbox.cashfree.com/pg

# ── Plan Prices (in paise — 1 rupee = 100 paise) ────────────
# These are backend-enforced prices — client cannot change them
# basic = ₹499/month, pro = ₹999/month, elite = ₹1999/month
# basic_yearly = ₹4499/year, pro_yearly = ₹8999/year
# (Already set in config.py — override here only if needed)

# ── News API ─────────────────────────────────────────────────
# Get free key from https://newsapi.org
# Without this, demo news data is shown
NEWS_API_KEY=your-newsapi-key

# ── AI Summary in Stock Analysis (optional) ──────────────────
# Uncomment ONE of these for AI-generated stock summaries
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ── Email (optional — for notifications) ─────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-gmail-app-password
FROM_EMAIL=noreply@yourdomain.com