# FinVest Pro — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to Git

# ── App ────────────────────────────────────────────────────
DEBUG=False
SECRET_KEY=change-this-use-openssl-rand-hex-32

# ── CORS (your frontend domain) ────────────────────────────
ALLOWED_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com","http://localhost:5500"]

# ── Firebase ───────────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=firebase/serviceAccountKey.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Database ───────────────────────────────────────────────
DATABASE_URL=sqlite:///./finvest.db
# DATABASE_URL=postgresql://user:password@localhost:5432/finvest

# ── Cashfree Payment ───────────────────────────────────────
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_BASE_URL=https://sandbox.cashfree.com/pg
# CASHFREE_BASE_URL=https://api.cashfree.com/pg   ← production

# ── News API (newsapi.org — free tier available) ───────────
NEWS_API_KEY=your_newsapi_key

# ── AI (optional — for richer stock analysis summaries) ───
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── Email Notifications (optional) ────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@finvestpro.in
