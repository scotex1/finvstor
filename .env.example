# FinVest Pro — Environment Variables
# Render pe "Environment" section mein yeh sab add karo
# Local dev ke liye: cp .env.example .env

# ════════════════════════════════════════════════════
# 🔴 REQUIRED — without these app won't start
# ════════════════════════════════════════════════════

DEBUG=False

# Generate karo: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=paste-your-32-char-random-string-here

# Firebase project ID (Firebase Console → Project Settings)
FIREBASE_PROJECT_ID=your-firebase-project-id

# ⭐ IMPORTANT: serviceAccountKey.json ka POORA content yahan paste karo
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# Copy the entire JSON and paste as single line below
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"..."}

# Your frontend domain (no trailing slash)
ALLOWED_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# Cashfree credentials (Cashfree Dashboard → Credentials → Production)
CASHFREE_APP_ID=CF1234567890
CASHFREE_SECRET_KEY=cfsk_ma_prod_xxxxxxxxxxxxxxxxxxxx
CASHFREE_BASE_URL=https://api.cashfree.com/pg

# ════════════════════════════════════════════════════
# 🟡 IMPORTANT — features work nahi karenge without these
# ════════════════════════════════════════════════════

# newsapi.org pe free account banao → API key milega
NEWS_API_KEY=your_newsapi_key_here

# ════════════════════════════════════════════════════
# 🟢 OPTIONAL — AI stock analysis ke liye
# ════════════════════════════════════════════════════

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# ════════════════════════════════════════════════════
# 🔵 DEFAULT — change karne ki zaroorat nahi
# ════════════════════════════════════════════════════

USE_SQLITE_CACHE=False
