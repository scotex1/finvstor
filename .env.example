cat > /home/claude/backend_refix/backend/.env.example << 'ENDOFFILE'
# FinVest Pro — Environment Variables
# ════════════════════════════════════════════════════════════════

# ── CRITICAL: Add YOUR frontend URL here ─────────────────────
# This fixes the CORS error
# Format: ["url1","url2"]  — exact match, no trailing slash
ALLOWED_ORIGINS=["https://scotex1.github.io","https://yourdomain.com","http://localhost:5500"]

# Regex — allows ANY github.io subdomain automatically
ALLOWED_ORIGIN_REGEX=https://.*\.github\.io

# ── App ───────────────────────────────────────────────────────
DEBUG=False
SECRET_KEY=paste-32-char-random-string-here

# ── Firebase ──────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
# Paste ENTIRE serviceAccountKey.json content as one line:
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com"}

# ── Cashfree ──────────────────────────────────────────────────
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret
CASHFREE_BASE_URL=https://api.cashfree.com/pg

# ── News API ──────────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key

# ── AI (optional) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
ALPHA_VANTAGE_API_KEY=



